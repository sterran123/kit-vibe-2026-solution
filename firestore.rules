rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // 1. 사용자 (users)
    // ==========================================
    match /users/{userId} {
      // 이메일 중복 확인용 - 회원가입 시 필요
      allow get: if true;
      // 자신의 프로필만 읽기/쓰기
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ==========================================
    // 2. 채팅 세션 (chat_sessions)
    // ==========================================
    match /chat_sessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // ==========================================
    // 3. 티켓 (tickets)
    // ==========================================
    match /tickets/{ticketId} {
      // 학생: 자신의 티켓 읽기
      // 강사: 할당된 티켓 또는 미할당 티켓 읽기
      // 관리자: 모든 티켓 읽기
      allow read: if request.auth != null && (
        resource.data.student_id == request.auth.uid ||
        resource.data.instructor_id == request.auth.uid ||
        (resource.data.instructor_id == null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // 학생만 티켓 생성
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.student_id &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';

      // 강사(할당된 경우) 또는 관리자만 업데이트
      allow update: if request.auth != null && (
        resource.data.instructor_id == request.auth.uid ||
        resource.data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // 관리자만 삭제
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // 4. 티켓 답변 (ticket_replies)
    // ==========================================
    match /ticket_replies/{replyId} {
      // 관련 티켓의 참여자만 읽기
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/tickets/$(resource.data.ticket_id)).data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/tickets/$(resource.data.ticket_id)).data.instructor_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // 티켓 참여자만 답변 작성
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/tickets/$(request.resource.data.ticket_id)).data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/tickets/$(request.resource.data.ticket_id)).data.instructor_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // 본인 답변만 수정/삭제
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.author_id;
    }

    // ==========================================
    // 5. 피드백 (feedbacks)
    // ==========================================
    match /feedbacks/{feedbackId} {
      // 자신의 피드백 읽기, 관리자는 모두 읽기
      allow read: if request.auth != null && (
        resource.data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // 학생만 자신의 피드백 생성
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.student_id;

      // 관리자만 상태 업데이트
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (resource.data.student_id == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['additional_comment']))
      );

      // 관리자만 삭제
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // 6. 알림 (notifications)
    // ==========================================
    match /notifications/{notificationId} {
      // 자신의 알림만 읽기
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;

      // 시스템 또는 자신만 생성 (시스템 알림은 서버에서 생성)
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;

      // 읽음 상태 업데이트만 허용
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.user_id &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read', 'read_at']);

      // 자신의 알림만 삭제
      allow delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }

    // ==========================================
    // 7. 강의 관련 (courses, courseRequests, courseEnrollments)
    // ==========================================
    match /courses/{courseId} {
      // 모든 인증 사용자 읽기
      allow read: if request.auth != null;
      // 강사/관리자만 생성/수정/삭제
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'];
    }

    match /courseRequests/{requestId} {
      // 학생: 자신의 요청, 강사/관리자: 모든 요청
      allow read: if request.auth != null && (
        resource.data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );
      // 학생만 생성
      allow create: if request.auth != null && request.auth.uid == request.resource.data.student_id;
      // 강사/관리자만 상태 업데이트
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'] ||
        resource.data.student_id == request.auth.uid
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /courseEnrollments/{enrollmentId} {
      // 자신의 등록 정보만 읽기, 강사/관리자는 모든 등록 정보
      allow read: if request.auth != null && (
        resource.data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );
      // 관리자/강사만 생성 (승인 시)
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'];
      // 자신의 진행 상황 업데이트 또는 관리자
      allow update: if request.auth != null && (
        resource.data.student_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // 8. 강의 진행률 (courseProgress)
    // ==========================================
    match /courseProgress/{progressId} {
      // progressId 형식: {courseId}_{userId}
      allow read: if request.auth != null && (
        progressId.matches('.*_' + request.auth.uid + '$') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );
      allow create: if request.auth != null && progressId.matches('.*_' + request.auth.uid + '$');
      allow update: if request.auth != null && (
        progressId.matches('.*_' + request.auth.uid + '$') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // 9. 커뮤니티 (posts, comments, announcements)
    // ==========================================
    match /posts/{postId} {
      // 모든 인증 사용자 읽기
      allow read: if request.auth != null;
      // 모든 인증 사용자 작성
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author_id;
      // 본인 또는 관리자만 수정/삭제
      allow update, delete: if request.auth != null && (
        resource.data.author_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author_id;
      allow update, delete: if request.auth != null && resource.data.author_id == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'];
    }

    // ==========================================
    // 10. 기본: 인증된 사용자만 접근
    // ==========================================
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
