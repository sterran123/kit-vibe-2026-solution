rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ==========================================
    // 1. 프로필 이미지 (profile-images/)
    // ==========================================
    match /profile-images/{userId}/{fileName} {
      // 모든 인증 사용자 읽기 가능
      allow read: if request.auth != null;
      // 자신의 폴더에만 쓰기 가능
      allow write: if request.auth != null && request.auth.uid == userId;
      // 파일 크기 제한: 5MB, 이미지 파일만
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ==========================================
    // 2. 강의 자료 (course-materials/)
    // ==========================================
    match /course-materials/{courseId}/{fileName} {
      // 인증된 사용자 읽기 (해당 강의 수강생 또는 강사)
      allow read: if request.auth != null;
      // 강사/관리자만 업로드
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'];
      // 파일 크기 제한: 100MB
      allow create: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
        && request.resource.size < 100 * 1024 * 1024;
    }

    // ==========================================
    // 3. 강의 썸네일 (course-thumbnails/)
    // ==========================================
    match /course-thumbnails/{courseId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin'];
      allow create: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['instructor', 'admin']
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ==========================================
    // 4. 수료증 (certificates/)
    // ==========================================
    match /certificates/{userId}/{fileName} {
      // Cloud Function에서 생성된 수료증 읽기
      allow read: if true;
      // 자신의 폴더에만 쓰기 (Cloud Function에서 생성)
      allow write: if request.auth != null && request.auth.uid == userId;
      // PDF 파일만 허용
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType == 'application/pdf';
    }

    // ==========================================
    // 5. 커뮤니티 첨부파일 (community-attachments/)
    // ==========================================
    match /community-attachments/{userId}/{fileName} {
      // 인증 사용자 읽기
      allow read: if request.auth != null;
      // 자신의 파일만 업로드
      allow write: if request.auth != null && request.auth.uid == userId;
      // 파일 크기 제한: 20MB
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }

    // ==========================================
    // 6. 티켓 첨부파일 (ticket-attachments/)
    // ==========================================
    match /ticket-attachments/{ticketId}/{fileName} {
      // 관련 티켓 참여자 읽기
      allow read: if request.auth != null;
      // 티켓 생성자 또는 담당 강사만 업로드
      allow write: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    // ==========================================
    // 7. 공용 에셋 (public-assets/)
    // ==========================================
    match /public-assets/{allPaths=**} {
      // 모든 사용자 읽기 가능
      allow read: if true;
      // 관리자만 업로드
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ==========================================
    // 8. 기본: 인증된 사용자만 접근
    // ==========================================
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
